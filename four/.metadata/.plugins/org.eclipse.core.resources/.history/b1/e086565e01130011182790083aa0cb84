<%@ taglib uri="jakarta.tags.core" prefix="c" %>

<html>
<body>

<h2>Employee Management</h2>

<a href="savePage">Add</a> |
<a href="searchPage">Search</a> |
<a href="updatePage">Update</a> |
<a href="deletePage">Delete</a>

<hr>

<table border="1">
<tr>
<th>ID</th>
<th>Name</th>
<th>Phone</th>
<th>Email</th>
</tr>

<c:forEach var="e" items="${list}">
<tr>
<td>${e.id}</td>
<td>${e.name}</td>
<td>${e.phone}</td>
<td>${e.email}</td>
</tr>
</c:forEach>

</table>

</body>
</html>