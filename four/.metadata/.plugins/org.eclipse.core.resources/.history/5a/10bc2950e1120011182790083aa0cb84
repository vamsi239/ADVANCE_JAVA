<%@ taglib uri="http://java.sun.com/jsp/jstl/core" prefix="c" %>

<html>
<body>

<h2>Employee Management System</h2>

<a href="savePage">Add Employee</a> |
<a href="searchPage">Search Employee</a> |
<a href="updatePage">Update Employee</a> |
<a href="deletePage">Delete Employee</a>

<hr>

<h3>All Employees</h3>

<table border="1">
<tr>
    <th>ID</th>
    <th>Name</th>
    <th>Phone</th>
    <th>Email</th>
</tr>

<c:forEach var="e" items="${list}">
<tr>
    <td>${e.id}</td>
    <td>${e.name}</td>
    <td>${e.phone}</td>
    <td>${e.email}</td>
</tr>
</c:forEach>

</table>

</body>
</html>